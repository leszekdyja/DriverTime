# Copy this file to .env and replace every CHANGE_ME value before deployment.
POSTGRES_DB=drivertime
POSTGRES_USER=drivertime
POSTGRES_PASSWORD=CHANGE_ME_LONG_DATABASE_PASSWORD
POSTGRES_PORT=5433

JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS
SEED_ADMIN_COMPANY=DriverTime
SEED_ADMIN_EMAIL=admin@drivertime.local
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Enable only for a public demo environment. Development seeds demo data automatically.
DEMO_DATA_ENABLED=false
DEMO_COMPANY_NAME=Northline Logistics
DEMO_EMAIL=demo@drivertime.app
DEMO_PASSWORD=DriverTimeDemo123!

PUBLIC_APP_URL=http://localhost:8080
WEB_PORT=8080
API_PORT=8081
